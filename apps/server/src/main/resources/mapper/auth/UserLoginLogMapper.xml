<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sapphire.domain.auth.mapper.UserLoginLogMapper">
    <insert id="insert" parameterType="com.sapphire.domain.auth.dto.UserLoginLog">
        INSERT INTO user_login_logs (
            user_id,
            email,
            success,
            failure_reason,
            ip_address,
            user_agent
        )
        VALUES (
            #{userId},
            #{email},
            #{success},
            #{failureReason},
            #{ipAddress},
            #{userAgent}
        )
    </insert>
</mapper>
