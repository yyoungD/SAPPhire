<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sapphire.domain.sapskill.mapper.SapSkillMapper">
    <select id="findAll" resultType="com.sapphire.domain.sapskill.dto.SapSkillResponse">
        SELECT
            id,
            code,
            name,
            description,
            skill_type AS skillType
        FROM sap_skills
        ORDER BY
            CASE skill_type
                WHEN 'MODULE' THEN 1
                WHEN 'SOLUTION' THEN 2
                WHEN 'TECHNICAL' THEN 3
                ELSE 4
            END,
            name
    </select>
</mapper>
